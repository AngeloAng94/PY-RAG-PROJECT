# ---------------------------------------------------------------------------
# RAG engine configuration (.env template)
# Copy to `.env` (repo root) and adjust. The package reads ONLY these keys.
# Everything is local-first: by default no data leaves the machine.
# ---------------------------------------------------------------------------

# On-disk location of the ChromaDB PersistentClient index.
RAG_INDEX_PATH=./.rag_index

# Which Embedder implementation to use. Selected by rag.embeddings.get_embedder.
#   local | openai_compatible  -> OpenAICompatibleEmbedder (default, on-machine)
#   cloud                      -> CloudEmbedderStub (must be implemented first)
RAG_EMBED_PROVIDER=local

# Embedding model name passed to the provider. MUST be identical for indexing
# and querying (mixing models silently destroys recall).
RAG_EMBED_MODEL=nomic-embed-text

# Base URL of the local embedding runtime exposing POST {BASE_URL}/embeddings
# in the OpenAI-compatible shape. Works with llama.cpp server, LM Studio, vLLM,
# Text-Embeddings-Inference (OpenAI route), Ollama's /v1 shim, etc.
RAG_EMBED_BASE_URL=http://localhost:11434/v1

# Optional bearer token. Local runtimes usually ignore it; leave empty.
RAG_EMBED_API_KEY=

# Per-request embedding HTTP timeout, in SECONDS. Local CPU embedding of a large
# input can take minutes — 60s is too low and crashes long builds. Default 300.
RAG_EMBED_TIMEOUT=300

# Default number of chunks to retrieve.
RAG_TOP_K=5

# Hard budget (characters) for retrieved EXAMPLE text injected into context.
# The target file under edit is always included in full and is NOT counted here.
RAG_MAX_EXAMPLE_CHARS=8000

# Upper bound (characters) on a single chunk. A function larger than this is
# split into sequential sub-chunks at line boundaries (never mid-line) so it
# can't stall the embedder or exceed the model input limit. Default 12000.
RAG_MAX_CHUNK_CHARS=12000

# A file whose LONGEST line exceeds this is treated as generated asset/data
# (e.g. an image-as-C pixel blob with 6000+ char lines) and skipped BEFORE
# embedding — it has no retrieval value and would time out the embedder.
# Conservative: well above normal C source lines. Default 2000.
RAG_MAX_DATA_LINE_CHARS=2000

# ---------------------------------------------------------------------------
# Optional: session dimensions for the retriever node when the real classifier
# is not wired yet. board/micro are mandatory for retrieval to run at all.
# (In production these come from the classifier via AgentState.)
# ---------------------------------------------------------------------------
# RAG_SESSION_BOARD=ASY011
# RAG_SESSION_MICRO=STM32H750
# RAG_SESSION_SCOPE=categoria
# RAG_SESSION_CATEGORIA=caffe
# RAG_SESSION_CLIENTE=
