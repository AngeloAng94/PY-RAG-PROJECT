# RAG Engine Configuration Template
# Copy this file to .env.rag and customize values for your environment
# DO NOT commit .env.rag to version control

# --- LLM / Embedding Model ---
RAG_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_MODEL_TYPE=sentence-transformers
RAG_LLM_MODEL_NAME=google/gemini-2.0-flash-lite
RAG_LLM_PROVIDER=gemini

# --- Local Runtime (Ollama / Local LLM) ---
RAG_LOCAL_RUNTIME_URL=http://localhost:11434
RAG_LOCAL_RUNTIME_ENABLED=false

# --- Chunking ---
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# --- Vector Store ---
RAG_VECTOR_STORE_TYPE=chromadb
RAG_VECTOR_STORE_PATH=./vector_store

# --- Retrieval ---
RAG_TOP_K=5
RAG_RETRIEVAL_THRESHOLD=0.5

# --- Cache ---
RAG_CACHE_ENABLED=true
RAG_CACHE_BACKEND=memory
RAG_CACHE_TTL=3600

# --- Logging ---
RAG_LOG_LEVEL=INFO
RAG_LOG_FILE=./logs/rag.log
